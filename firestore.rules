rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read site configurations, blogs, careers, and faqs
    match /site_content/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blogs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /careers/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /faqs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Anyone can submit inquiries and job applications, but only authenticated admins can manage them
    match /inquiries/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /applications/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Live chats: Anyone can start a session and post messages.
    // Admins can read/write to all of them.
    match /chat_sessions/{sessionId} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // Project deliverables: Accessible only by admins and the designated client
    match /deliverables/{deliverableId} {
      allow read: if request.auth != null && (
        request.auth.token.email.lower() == "somilsrivastav18@gmail.56da".lower() ||
        request.auth.token.email.lower() == "somilsrivastav18@gmail.com" || 
        resource.data.clientEmail.lower() == request.auth.token.email.lower()
      );
      allow create: if request.auth != null && (
        request.auth.token.email.lower() == "somilsrivastav18@gmail.56da".lower() ||
        request.auth.token.email.lower() == "somilsrivastav18@gmail.com" || 
        request.resource.data.clientEmail.lower() == request.auth.token.email.lower()
      );
      allow update, delete: if request.auth != null && (
        request.auth.token.email.lower() == "somilsrivastav18@gmail.56da".lower() ||
        request.auth.token.email.lower() == "somilsrivastav18@gmail.com" || 
        resource.data.clientEmail.lower() == request.auth.token.email.lower()
      );
    }

    // Deliverables chats and messages: Accessible only by admins and the matching client
    match /deliverables_chats/{clientEmail} {
      allow read, write: if request.auth != null && (
        request.auth.token.email.lower() == "somilsrivastav18@gmail.56da".lower() ||
        request.auth.token.email.lower() == "somilsrivastav18@gmail.com" || 
        clientEmail.lower() == request.auth.token.email.lower()
      );
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          request.auth.token.email.lower() == "somilsrivastav18@gmail.56da".lower() ||
          request.auth.token.email.lower() == "somilsrivastav18@gmail.com" || 
          clientEmail.lower() == request.auth.token.email.lower()
        );
      }
    }
  }
}
