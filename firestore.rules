rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone can read site configurations, blogs, careers, and faqs
    match /site_content/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /blogs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /careers/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /faqs/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Anyone can submit inquiries and job applications, but only authenticated admins can manage them
    match /inquiries/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /applications/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Live chats: Anyone can start a session and post messages.
    // Admins can read/write to all of them.
    match /chat_sessions/{sessionId} {
      allow read, write: if true;
      
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
